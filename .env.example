# Ambiente de execução: dev | prod
# Controla formato de log (console colorido em dev, JSON em prod) e flags de debug.
ENV=dev

# Nível mínimo de log. Valores: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=DEBUG

# PostgreSQL + TimescaleDB
# POSTGRES_PASSWORD é gerado automaticamente pelo scripts/bootstrap-env.sh.
# NUNCA commitar o .env real. Permissão 600, dono polycopy:polycopy.
POSTGRES_USER=polycopy
POSTGRES_PASSWORD=__GENERATED__
POSTGRES_DB=polycopy
POSTGRES_PORT=5432

# NATS JetStream — barramento de eventos entre agentes.
NATS_URL=nats://localhost:4222

# Redis — cache (sem persistência). Database 0.
REDIS_URL=redis://localhost:6379/0

# Prometheus — porta de scrape no host (loopback).
PROMETHEUS_PORT=9090
