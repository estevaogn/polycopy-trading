# Ambiente de execução: dev | prod
# Controla formato de log (console colorido em dev, JSON em prod) e flags de debug.
ENV=dev

# Nível mínimo de log. Valores: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=DEBUG

# PostgreSQL + TimescaleDB
# POSTGRES_PASSWORD é gerado automaticamente pelo scripts/bootstrap-env.sh.
# NUNCA commitar o .env real. Permissão 600, dono polycopy:polycopy.
POSTGRES_USER=polycopy
POSTGRES_PASSWORD=__GENERATED__
POSTGRES_DB=polycopy
POSTGRES_PORT=5432
POSTGRES_HOST=127.0.0.1

# NATS JetStream — barramento de eventos entre agentes.
NATS_URL=nats://localhost:4222

# Redis — cache (sem persistência). Database 0.
REDIS_URL=redis://localhost:6379/0

# Prometheus — porta de scrape no host (loopback).
PROMETHEUS_PORT=9090

# Watcher
WATCHER_INTERVAL_S=5
WATCHER_BOOTSTRAP_HOURS=24
WATCHER_METRICS_PORT=9101
# Lista CSV de endereços. DEPRECATED após Task 4 — usar config/wallets_seed.yaml.
# Mantido apenas pelo esqueleto da Task 3.
WATCH_WALLETS=
WALLETS_SEED_PATH=config/wallets_seed.yaml
POLYMARKET_BASE_URL=https://data-api.polymarket.com

# Notifier
NOTIFIER_METRICS_PORT=9102
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Market data agent (Plano 2A) ---
GAMMA_API_BASE_URL=https://gamma-api.polymarket.com
CLOB_API_BASE_URL=https://clob.polymarket.com
MARKETDATA_METRICS_PORT=9103
MARKETDATA_SYNC_INTERVAL_SECONDS=300
MARKETDATA_TOP_N=200
MARKET_CACHE_TTL_SECONDS=1800

# --- Risk agent (Plano 2B) ---
RISK_METRICS_PORT=9104
RISK_MAX_DELIVER=5
RISK_DURABLE_NAME=risk-1
RISK_MAX_TRADE_USDC=100
RISK_MIN_PRICE=0.05
RISK_MAX_PRICE=0.95
RISK_MIN_LIQUIDITY_USDC=1000
RISK_GAMMA_FETCH_TIMEOUT_S=5.0

# --- Sizing agent (Plano 2C) ---
SIZING_METRICS_PORT=9105
SIZING_MAX_DELIVER=5
SIZING_DURABLE_NAME=sizing-1
SIZING_PROPORTION_RATIO=0.1
SIZING_MAX_SIZE_USDC=50
SIZING_MIN_SIZE_USDC=1

# --- Executor agent (Plano 3 — DRY-RUN MVP) ---
EXECUTOR_METRICS_PORT=9106
EXECUTOR_MAX_DELIVER=5
EXECUTOR_DURABLE_NAME=executor-1
EXECUTOR_DRY_RUN=true
