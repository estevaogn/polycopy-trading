# syntax=docker/dockerfile:1.7
# ---- builder ----
FROM python:3.12-slim AS builder
RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*
COPY --from=ghcr.io/astral-sh/uv:0.5 /uv /uvx /bin/
WORKDIR /app
COPY pyproject.toml uv.lock README.md ./
COPY src/ src/
RUN uv sync --frozen --no-dev

# ---- runtime ----
FROM python:3.12-slim
RUN useradd --create-home --uid 1000 polycopy
WORKDIR /app
COPY --from=builder /app/.venv /app/.venv
COPY --from=builder /app/src /app/src
COPY config/ config/
ENV PATH="/app/.venv/bin:$PATH" \
    PYTHONPATH=/app/src \
    PYTHONUNBUFFERED=1
ARG AGENT_MODULE
RUN test -n "${AGENT_MODULE}" || (echo "ERROR: AGENT_MODULE build arg required (watcher|notifier)" && exit 1)
ENV AGENT_MODULE=${AGENT_MODULE}
USER polycopy
ENTRYPOINT ["sh", "-c", "exec python -m polycopy.agents.${AGENT_MODULE}"]
